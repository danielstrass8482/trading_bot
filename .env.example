# .env.example – Template für Umgebungsvariablen
# Kopiere diese Datei zu .env und fülle die Werte aus
# WICHTIG: .env niemals in Git committen!

# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-...

# Alpaca Markets (https://alpaca.markets)
ALPACA_API_KEY=...
ALPACA_SECRET_KEY=...

# Trading-Modus: PAPER oder LIVE
# PAPER = simulierter Handel ohne echtes Geld
# LIVE  = echte Orders (erst nach erfolgreicher Paper-Phase!)
TRADING_MODE=PAPER

# Alerts (optional)
ALERT_EMAIL=deine@email.de

# SMTP für E-Mail-Versand (optional – ohne diese Werte wird nur geloggt)
# Port 465 (SSL) ist Standard, da Railway Port 587 (STARTTLS) blockiert.
# SMTP_FALLBACK_PORT greift, falls auch 465 blockiert/nicht erreichbar ist.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_FALLBACK_PORT=2525
SMTP_USER=absender@gmail.com
SMTP_PASSWORD=app-passwort

# Datenbank (Standard: lokale SQLite-Datei)
# Für Railway.app: wird automatisch gesetzt
DATABASE_URL=sqlite:///trading_bot.db
